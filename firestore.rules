rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "joaquinvillanuevavarela@gmail.com" ||
        request.auth.token.email == "valentina@yoga.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && 
                    incoming().userId == userId &&
                    (incoming().role == "student" || isAdmin()) &&
                    incoming().displayName is string &&
                    incoming().email is string;
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && 
                    incoming().role == existing().role &&  // Forbid self-role escalation
                    incoming().userId == existing().userId &&
                    incoming().email == existing().email));
      allow delete: if isAdmin();
    }

    // --- Packages Collection ---
    match /packages/{packageId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    (incoming().studentId == request.auth.uid || isAdmin()) &&
                    incoming().packageId == packageId &&
                    incoming().totalClasses is number &&
                    incoming().remainingClasses is number &&
                    incoming().pricePaid is number &&
                    incoming().type in ["10_classes", "20_classes", "unlimited"];
                    
      allow update: if isSignedIn() && (
                    isAdmin() || 
                    (resource.data.studentId == request.auth.uid && 
                     incoming().packageId == existing().packageId &&
                     incoming().studentId == existing().studentId &&
                     incoming().totalClasses == existing().totalClasses &&
                     incoming().remainingClasses == existing().remainingClasses && // Student can't change classes remaining
                     incoming().type == existing().type &&
                     incoming().pricePaid == existing().pricePaid)
                  );
                  
      allow delete: if isAdmin();
    }

    // --- Classes Collection ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    (incoming().studentId == request.auth.uid || isAdmin()) &&
                    incoming().bookingId == bookingId &&
                    incoming().classId is string &&
                    incoming().className is string &&
                    incoming().instructor is string &&
                    incoming().classDate is string &&
                    incoming().classTime is string &&
                    incoming().status == "booked";
                    
      allow update: if isSignedIn() && (
                    isAdmin() || 
                    (resource.data.studentId == request.auth.uid && 
                     incoming().bookingId == existing().bookingId &&
                     incoming().studentId == existing().studentId &&
                     incoming().classId == existing().classId &&
                     incoming().classDate == existing().classDate &&
                     incoming().classTime == existing().classTime &&
                     incoming().status == "cancelled" && // Student can only cancel booking
                     existing().status == "booked")
                  );
                  
      allow delete: if isAdmin();
    }

    // --- Expenses Collection ---
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }
  }
}
